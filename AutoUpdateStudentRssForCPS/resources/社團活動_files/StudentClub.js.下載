 function onClubMsgSuccess(result,context,methodName)
        {
           
            //alert(methodName);
           if (methodName=="GetClubPermissionList")
           {
                return;     
           }
           
           if (methodName=='SelectClubQuipmentTypeLightLicense')
            {
                RefreshLightLicense(result);  
                return;  
            }
            
            alert(result);
        }
        
 function onNewClubMsgFail(error,context,methodName)
        {
            alert(error.get_message());
        }
        
        
        
        

        