 Sys.WebForms.PageRequestManager.getInstance().add_endRequest(EndRequestHandler);
 
function EndRequestHandler(sender, args)
 {
     if (args.get_error() != undefined && args.get_error().httpStatusCode == '500')
    {
      var errorMessage = args.get_error().message
      args.set_errorHandled(true);
      alert(errorMessage);
                       
    }

 }
 
 
 
 function InsertNewClubGroup(s,Pck2,ClubID,ManageFlag)
        {
          
            var NewClubGroupName=s;
            var PermissionSNoString='';
            var PermissionSNoStringSplitChar=';';
            var h=0;
            for (h=0;h<Pck2.length;h++)
            {
                if (Pck2[h].checked==true)
                {
                    if (PermissionSNoString!='')
                        PermissionSNoString=PermissionSNoString+PermissionSNoStringSplitChar+Pck2[h].value;
                    else
                        PermissionSNoString=Pck2[h].value;
                 }
            }
            

            YzuClub.ClubWebService.NewClubGroup(ManageFlag,ClubID,NewClubGroupName,PermissionSNoString,PermissionSNoStringSplitChar,onClubMsgSuccess,onNewClubMsgFail,"<%=DateTime.Now %>")
    
        }






